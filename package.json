{
  "name": "vellum",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "bash scripts/quickstart.sh",
    "start": "bun run --filter @vellum/web build && bun packages/web/src/server.ts",
    "demo": "bun scripts/demo.ts",
    "dev": "bun run --filter '@vellum/*' dev",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "prettier": "3.3.3",
    "typescript": "5.5.4",
    "@vellum/chain": "workspace:*",
    "@vellum/engine": "workspace:*",
    "@vellum/shared": "workspace:*",
    "@vellum/tokenization": "workspace:*"
  },
  "overrides": {
    "protobufjs": "7.6.1",
    "ws": "8.20.1"
  }
}
