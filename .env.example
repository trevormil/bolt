# Chain (Meridian devnet — see docs/runbooks/meridian-devnet.md). Defaults applied if unset.
BITBADGES_CHAIN_ID=bitbadges-1
BITBADGES_RPC=https://rpc.meridian.trevormil.com
BITBADGES_LCD=https://lcd.meridian.trevormil.com

# Agent signer (devnet dev key). NEVER commit a real key — set in your local .env only.
# Provided at build time (ticket 0002); leave unset for the scaffold.
# AGENT_SIGNER_MNEMONIC=
# AGENT_SIGNER_PRIVKEY_HEX=

# Telegram (ticket 0003)
# TELEGRAM_BOT_TOKEN=

# LLM providers (ticket 0004) — at least one once the agent loop lands
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Langfuse observability (ticket 0021 — reuse AgentForge W1-3 key/endpoint)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# Logging
LOG_LEVEL=info
